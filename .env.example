DOMAIN=swimcoach.example.com

# Image tags — update after each build (use the sha tag for pinned deploys)
BACKEND_IMAGE=ghcr.io/<github-username>/swimcoach-back-end:latest
FRONTEND_IMAGE=ghcr.io/<github-username>/swimcoach-front-end:latest

# PostgreSQL
POSTGRES_PASSWORD=<strong-random-password>

# Backend app secrets
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/swimcoach
SECRET_KEY=<output-of: openssl rand -hex 32>

# Frontend
API_URL=http://backend:8000
