DOMAIN=swimcoach.example.com

# Image tags — update after each build (use the sha tag for pinned deploys)
BACKEND_IMAGE=ghcr.io/<github-username>/swimcoach-back-end:latest
FRONTEND_IMAGE=ghcr.io/<github-username>/swimcoach-front-end:latest

# PostgreSQL
POSTGRES_PASSWORD=<strong-random-password>

# Redis (rate limiter storage)
REDIS_PASSWORD=<strong-random-password>

# Backend app secrets
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/swimcoach
SECRET_KEY=<output-of: openssl rand -hex 32>

# Frontend
API_URL=http://backend:8000
# Set to true only once the site is ready for search engines/crawlers.
SITE_INDEXABLE=false
# Cloudflare Turnstile (sign-up CAPTCHA) secret key — from the Cloudflare
# dashboard. Required: the frontend fails closed (rejects all sign-ups) if
# this is unset. The matching site key is NOT set here — it's baked in at
# image build time, not read at container runtime (see cd.yml).
TURNSTILE_SECRET_KEY=<from-cloudflare-dashboard>
